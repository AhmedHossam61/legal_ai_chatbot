# ══════════════════════════════════════════════════════
#  Legal AI Demo – Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  Do NOT commit the .env file to version control.
# ══════════════════════════════════════════════════════

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-openai-api-key-here...

# ── LLM Settings ───────────────────────────────────────────────────────────────
LLM_MODEL=gpt-4o-mini          # Options: gpt-4o, gpt-4o-mini, gpt-3.5-turbo
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBED_MODEL=text-embedding-3-small

# ── RAG ────────────────────────────────────────────────────────────────────────
RAG_TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── ASR (Speech-to-Text) ───────────────────────────────────────────────────────
ASR_PROVIDER=openai             # Options: openai, local_whisper
ASR_MODEL=whisper-1
# LOCAL_WHISPER_MODEL=base      # Used only when ASR_PROVIDER=local_whisper

# ── TTS (Text-to-Speech) ───────────────────────────────────────────────────────
TTS_PROVIDER=openai             # Options: openai, gtts
TTS_MODEL=tts-1
TTS_VOICE=nova                  # Options: alloy, echo, fable, onyx, nova, shimmer

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=true
