# ══════════════════════════════════════════════════════
#  Legal AI Demo – Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  Do NOT commit the .env file to version control.
# ══════════════════════════════════════════════════════

# ── Google Gemini API Key (free at aistudio.google.com/apikey) ─────────────────
GEMINI_API_KEY=AIza...your-gemini-api-key-here...

# ── LLM Settings ───────────────────────────────────────────────────────────────
LLM_MODEL=gemini-2.0-flash     # Free. Alternatives: gemini-1.5-pro, gemini-2.5-flash
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048

# ── Embeddings ─────────────────────────────────────────────────────────────────
EMBED_MODEL=models/text-embedding-004    # Google's best embedding model (free)

# ── RAG ────────────────────────────────────────────────────────────────────────
RAG_TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── ASR (Speech-to-Text) ───────────────────────────────────────────────────────
ASR_PROVIDER=gemini             # Options: gemini (free), local_whisper (offline)
ASR_MODEL=gemini-2.0-flash      # Multimodal model used for audio transcription
# LOCAL_WHISPER_MODEL=base      # Used only when ASR_PROVIDER=local_whisper

# ── TTS (Text-to-Speech) ───────────────────────────────────────────────────────
TTS_PROVIDER=gemini             # Options: gemini (free, HD quality), gtts (free, lighter)
TTS_MODEL=gemini-2.5-flash-preview-tts
# Voices: Aoede, Kore, Puck, Fenrir, Charon, Leda, Orus, Zephyr, Autonoe, Sulafat
TTS_VOICE=Aoede

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=true
